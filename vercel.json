{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        { "src": "/style.css", "dest": "/style.css" },
        { "src": "/script.js", "dest": "/script.js" },
        { "src": "/api/lookup.php", "dest": "/api/lookup.php" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
